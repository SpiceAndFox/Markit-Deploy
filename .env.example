# Copy this file to .env on the A100 server and edit the host paths.

# Build options
TORCH_VERSION=2.6.0
TORCHVISION_VERSION=0.21.0
INSTALL_FLASH_ATTN=0
TRANSFORMERS_VERSION=4.57.3
TIKTOKEN_VERSION=0.13.0
TRANSFORMERS_STREAM_GENERATOR_VERSION=0.0.5
ULTRALYTICS_VERSION=8.3.101
ULTRALYTICS_CLIP_REF=81ff68ed7ffcac3b40484c914f104f816757308d
NUMPY_VERSION=1.26.4

# GPU selection inside the container
CUDA_VISIBLE_DEVICES=0

# Optional tokens, only needed for gated/private models.
HF_TOKEN=
MODELSCOPE_TOKEN=

# Optional proxy. Use this when the host needs a proxy to reach GitHub/Hugging Face/PyPI.
# Docker Desktop on Windows/macOS can usually reach the host proxy through host.docker.internal.
# Example for Clash/V2Ray HTTP proxy:
# Do not use 127.0.0.1 here. Inside Docker, 127.0.0.1 means the container.
# On a remote A100 server, host.docker.internal means that server, not your laptop.
DOCKER_HTTP_PROXY=
DOCKER_HTTPS_PROXY=
DOCKER_ALL_PROXY=
DOCKER_NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Optional proxy for host-side model download script. Use the address that works
# on the host running tools/download_models.py.
# Example: DOWNLOAD_HTTP_PROXY=http://127.0.0.1:7890
DOWNLOAD_HTTP_PROXY=
DOWNLOAD_HTTPS_PROXY=
DOWNLOAD_ALL_PROXY=
DOWNLOAD_NO_PROXY=localhost,127.0.0.1

# Host paths
MARKIT_CODE_DIR=.
MARKIT_MODEL_ROOT=/root/Ckpts/Markit
HF_CACHE_DIR=/root/Ckpts/hf-cache
MARKIT_DATA_ROOT=/root/Datasets
MARKIT_DATA_VOLUME_MODE=rw
MARKIT_OUTPUT_ROOT=/root/Markit-Deploy/outputs

# Container paths
QWEN25_VL_MODEL_PATH=/models/local/Qwen2.5-VL-7B-Instruct
SUBJECT_LLM_MODEL_PATH=/models/local/Qwen2.5-7B-Instruct
OVERLAY_ROOT=/data/MarkIt/Charades
RAW_VIDEO_ROOT=/data/Raw/Charades-Video
TEST_PATH=/data/MarkIt/test.json
SAVE_PATH=outputs/predictions/charades_markit_qwen25vl.json
YOLOE_WEIGHTS_PATH=/models/local/YOLOE-Large/yoloe-v8l-seg.pt

# Model download defaults
MODEL_SOURCE=modelscope
QWEN25_VL_REPO=Qwen/Qwen2.5-VL-7B-Instruct
SUBJECT_LLM_REPO=Qwen/Qwen2.5-7B-Instruct
SUBJECT_LLM_DIR=Qwen2.5-7B-Instruct
YOLOE_REPO=jameslahm/yoloe
YOLOE_WEIGHTS=yoloe-v8l-seg.pt
# ModelScope repos used when MODEL_SOURCE=modelscope.
MODELSCOPE_QWEN25_VL_REPO=Qwen/Qwen2.5-VL-7B-Instruct
MODELSCOPE_SUBJECT_LLM_REPO=Qwen/Qwen2.5-7B-Instruct
# YOLOE's default upstream is Hugging Face. For domestic-only downloads,
# either mirror it to ModelScope and set MODELSCOPE_YOLOE_REPO, provide
# a direct domestic URL through YOLOE_URLS, or use an HF-compatible mirror.
MODELSCOPE_YOLOE_REPO=
YOLOE_URLS=
YOLOE_HF_ENDPOINT=https://hf-mirror.com
SKIP_YOLOE=0

# Evaluation options
MAX_SAMPLES=-1
NUM_SAMPLED_FRAMES=32
